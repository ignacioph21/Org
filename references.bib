  keywords = {Experimental,Resonancias,Sección eficaz,Tesis de Licenciatura,Wave Turbulence},
  file = {/home/ignacio/Zotero/storage/NH4674E5/Mcgoldrick et al. - 1966 - Measurements of third-order resonant wave interactions.pdf}
}

