@article{bokhoveBreakingWavesDynamic2012,
  title = {Breaking {{Waves}} on a Dynamic {{Hele-Shaw Beach}}},
  author = {Bokhove, Onno and Zweers, Wout and Thornton, Anthony},
  date = {2012},
  abstract = {We report the formation of quasi-steady beaches and dunes via breaking waves in our tabletop ‘Hele-Shaw’ beach experiment. Breaking waves are generated by a wave maker, and zeolite particles act as sand. The tank is narrow, just over one-particle diameter wide, creating a quasi-2D set-up. Classical breaker types are observed on a time-scale of about a second. Beach formation under breakers occurs on a longer time-scale, and is a matter of minutes for a range of mono-chromatic wave frequencies. Alternating the wave maker motion between two frequencies generally leads to beach formation but occasionally to formation of a stable dune with water on either side. Finally, the Hele-Shaw configuration explored here experimentally lends itself to multi-scale modeling of beach dynamics.},
  langid = {english},
  keywords = {Setup Hele-Shaw},
  file = {/home/ignacio/Zotero/storage/DLWJZYEI/Bokhove et al. - 2012 - Breaking Waves on a dynamic Hele-Shaw Beach.pdf}
}

@article{bokhoveWAVEDRIVENSHINGLEBEACH2014,
  title = {{{ON WAVE-DRIVEN}} "{{SHINGLE}}† {{BEACH DYNAMICS IN A TABLE-TOP HELE-SHAW CELL}}},
  author = {Bokhove, Onno and Van Der Horn, A.J. and Van Der Meer, Devaraj and Thornton, Anthony R. and Zweers, Wout},
  date = {2014-10-28},
  journaltitle = {Coastal Engineering Proceedings},
  shortjournal = {Coast. Eng. Proc.},
  number = {34},
  pages = {41},
  issn = {2156-1028, 0589-087X},
  doi = {10.9753/icce.v34.sediment.41},
  url = {https://icce-ojs-tamu.tdl.org/icce/article/view/7454},
  urldate = {2026-04-20},
  abstract = {The primary evolution of beaches by wave action takes place during storms. Beach evolution by non-linear breaking waves is 3D, multi-scale, and involves particle-wave interactions. We will show how a novel, three-phase extension to the classic “Hele-Shaw” laboratory experiment is designed to create beach morphologies with breaking waves in a quasi-2D setting. Idealized beaches emerge in tens of minutes due to several types of breaking waves, with about 1s periods. The thin Hele-Shaw cell simplifies the inherent complexity of three-phase dynamics by reducing the turbulence. Given the interest in the Hele-Shaw table-top demonstrations at ICCE2014, we will also discuss how different versions of the Hele-Shaw cell have been constructed. Construction can be inexpensive thus yielding an accessible and flexible coastal engineering demonstration as well as research tool. Beach evolution is sufficiently fast and can start very far from equilibrium, allowing an unusually large dynamical range to be investigated.},
  langid = {english},
  keywords = {Setup Hele-Shaw},
  file = {/home/ignacio/Zotero/storage/3DQ853HS/Bokhove et al. - 2014 - ON WAVE-DRIVEN SHINGLE† BEACH DYNAMICS IN A TABLE-TOP HELE-SHAW CELL.pdf}
}

